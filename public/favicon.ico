<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
  <defs>
    <linearGradient id="sc-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#6366f1" />
      <stop offset="100%" stop-color="#06b6d4" />
    </linearGradient>
    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="1.2" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>
  <!-- Deep Dark Background -->
  <rect width="32" height="32" rx="8" fill="#0a0a1a" />
  <!-- Glowing Hexagon Outline -->
  <polygon points="16,4 27,10 27,22 16,28 5,22 5,10" fill="none" stroke="url(#sc-grad)" stroke-width="1.5" filter="url(#glow)" stroke-linejoin="round" opacity="0.9" />
  <!-- Glowing Monogram SC -->
  <text x="16" y="20.5" font-family="system-ui, -apple-system, sans-serif" font-size="11" font-weight="900" fill="url(#sc-grad)" text-anchor="middle" letter-spacing="0.2" filter="url(#glow)">SC</text>
</svg>
